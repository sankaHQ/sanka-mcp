{
  "name": "sanka-mcp",
  "version": "0.0.1",
  "description": "The official MCP Server for the Sanka API",
  "author": "Sanka <>",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sankaHQ/sanka-mcp.git"
  },
  "homepage": "https://github.com/sankaHQ/sanka-mcp#readme",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "private": true,
  "scripts": {
    "build": "bash ./build",
    "browser-use-worker": "ts-node -r tsconfig-paths/register src/browser-use-worker.ts",
    "format": "prettier --write --cache --cache-strategy metadata . !dist",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "eslint .",
    "fix": "eslint --fix ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@valtown/deno-http-worker": "^0.0.21",
    "ajv": "^8.18.0",
    "express": "^5.1.0",
    "fuse.js": "^7.1.0",
    "minisearch": "^7.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qs": "^6.14.1",
    "sanka-sdk": "workspace:*",
    "typescript": "5.8.3",
    "yargs": "^17.7.2",
    "zod": "^3.25.20"
  },
  "bin": {
    "mcp-server": "dist/index.js",
    "sanka-browser-use-worker": "dist/browser-use-worker.js"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.4.0",
    "@types/qs": "^6.14.0",
    "@types/yargs": "^17.0.8",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "eslint": "^9.39.1",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.4.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-morph": "^19.0.0",
    "ts-node": "^10.5.0",
    "tsc-multi": "https://github.com/stainless-api/tsc-multi/releases/download/v1.1.9/tsc-multi.tgz",
    "tsconfig-paths": "^4.0.0"
  },
  "imports": {
    "sanka-mcp": ".",
    "sanka-mcp/*": "./src/*"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./*.mjs": "./dist/*.mjs",
    "./*.js": "./dist/*.js",
    "./*": {
      "require": "./dist/*.js",
      "default": "./dist/*.mjs"
    }
  }
}
