{
  "dxt_version": "0.2",
  "name": "sanka-mcp",
  "version": "0.0.1",
  "description": "The official MCP Server for the Sanka API",
  "author": {
    "name": "Sanka"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sankaHQ/sanka-node.git"
  },
  "homepage": "https://github.com/sankaHQ/sanka-node/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.sanka.com/en/developers/api",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "SANKA_API_KEY": "${user_config.SANKA_API_KEY}"
      }
    }
  },
  "user_config": {
    "SANKA_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
